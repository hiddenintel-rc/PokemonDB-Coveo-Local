# Template only — copy to `.env` or `.env.local` and add real values. Commit `.env.example`, never `.env` / `.env.local`.
# Coveo: Anonymous Search template key for local/public index only.
NEXT_PUBLIC_COVEO_ORG_ID=
NEXT_PUBLIC_COVEO_API_KEY=
# Search hub: stable label for your UI (analytics / pipelines). If your Anonymous key *enforces* a hub (e.g. AdminConsole), set the same value here.
NEXT_PUBLIC_COVEO_SEARCH_HUB=PokemonSearch

# Optional — sprites: run tools/local-sprite-server (see docs/sprite-assets-local-handoff.md).
# Primary: tunnel or loopback; must match CSP + next/image remotePatterns.
# NEXT_PUBLIC_SPRITE_ASSET_BASE_URL=http://127.0.0.1:8787
# Optional mirror (same path layout as PokeAPI `sprites/`). Retried when primary errors (e.g. tunnel 502).
# NEXT_PUBLIC_SPRITE_FALLBACK_ASSET_BASE_URL=https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites
