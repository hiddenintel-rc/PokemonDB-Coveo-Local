# Repository root — use with `git init` here (app + docs). Nested rules in `web/.gitignore`
# still apply under `web/` (e.g. `.env`, `node_modules`, `.next`).

# Secrets at repo root (never commit real values)
.env
.env.local
.env.*.local

# Local scratch / IDE uploads sometimes land under the project folder
uploads/

# OS / editor noise
.DS_Store
Thumbs.db
*.log

# Dependencies (any package under the repo, e.g. web/)
node_modules/

# Optional local-only tooling (not published — avoids shipping Playwright/Push automation;
# clonees can recreate with their own scripts; secrets stay in ignored .env files only)
tools/seed-ml/
tools/push-yaml/

# Legacy local sprite package path (use committed `tools/local-sprite-server` instead)
web/pokemon-asset-hosted/
